{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hallelujah",
  "version": "0.1.0",
  "identifier": "com.hallelujah.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Hallelujah",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": [
      "binaries/sc-gin",
      "binaries/sc-express",
      "binaries/sc-fastapi",
      "binaries/sc-nest"
    ]
  }
}
